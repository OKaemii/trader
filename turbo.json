{
    "$schema": "https://turborepo.com/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "dist/.tsbuildinfo"]
        },
        "typecheck": {
            "dependsOn": ["^build"],
            "outputs": ["dist/.tsbuildinfo"]
        },
        "lint": {},
        "test": {
            "dependsOn": ["build"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}
