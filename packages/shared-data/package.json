{
  "name": "@trader/shared-data",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters/MongoDataAdapter": {
      "types": "./dist/adapters/MongoDataAdapter.d.ts",
      "import": "./dist/adapters/MongoDataAdapter.js"
    },
    "./adapters/RedisCacheAdapter": {
      "types": "./dist/adapters/RedisCacheAdapter.d.ts",
      "import": "./dist/adapters/RedisCacheAdapter.js"
    },
    "./adapters/RedisCacheInvalidationBus": {
      "types": "./dist/adapters/RedisCacheInvalidationBus.d.ts",
      "import": "./dist/adapters/RedisCacheInvalidationBus.js"
    },
    "./interfaces/IDataManager": {
      "types": "./dist/interfaces/IDataManager.d.ts",
      "import": "./dist/interfaces/IDataManager.js"
    },
    "./interfaces/ICache": {
      "types": "./dist/interfaces/ICache.d.ts",
      "import": "./dist/interfaces/ICache.js"
    },
    "./interfaces/ICacheInvalidationBus": {
      "types": "./dist/interfaces/ICacheInvalidationBus.d.ts",
      "import": "./dist/interfaces/ICacheInvalidationBus.js"
    }
