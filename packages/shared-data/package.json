  "dependencies": {
    "mongodb": "^6.5.0",
    "redis": "^4.7.0"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
